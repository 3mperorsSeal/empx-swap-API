{
  "annotations": { "list": [] },
  "description": "Per-partner API key usage: traffic, error rates, endpoint breakdown, and key activity",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "title": "API Overview",
