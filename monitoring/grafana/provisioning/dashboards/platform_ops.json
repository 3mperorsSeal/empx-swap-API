{
  "title": "DEX Platform Operations",
  "uid": "dex-platform-ops",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "tags": ["platform", "operations", "transactions"],
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Transaction Monitoring",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Pending Transactions",
      "description": "Transactions currently in pending state",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "postgres"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          },
          "mappings": [],
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "postgres"
          },
          "format": "table",
          "rawSql": "SELECT COUNT(*) AS value FROM pending_transactions WHERE status = 'pending'",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Failed Transactions",
      "description": "Transactions that encountered errors",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "postgres"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "postgres"
          },
          "format": "table",
          "rawSql": "SELECT COUNT(*) AS value FROM pending_transactions WHERE status = 'failed'",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Stuck Transactions",
      "description": "Pending for more than 10 minutes",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "postgres"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "dark-red", "value": 5 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "postgres"
          },
          "format": "table",
          "rawSql": "SELECT COUNT(*) AS value FROM pending_transactions WHERE status = 'pending' AND created_at < NOW() - INTERVAL '10 minutes'",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Completed Today",
      "description": "Transactions completed since midnight UTC",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "postgres"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "postgres"
          },
          "format": "table",
          "rawSql": "SELECT COUNT(*) AS value FROM pending_transactions WHERE status = 'completed' AND created_at >= NOW()::date",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Transaction Volume Over Time by Status",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 5 },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "postgres"
      },
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Failed" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "red", "mode": "fixed" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Pending" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "orange", "mode": "fixed" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Completed" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "green", "mode": "fixed" }
              }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "postgres"
          },
          "format": "time_series",
          "rawSql": "SELECT\n  $__timeGroupAlias(created_at,$__interval,'none'),\n  COUNT(*) FILTER (WHERE status = 'pending')   AS \"Pending\",\n  COUNT(*) FILTER (WHERE status = 'completed') AS \"Completed\",\n  COUNT(*) FILTER (WHERE status = 'failed')    AS \"Failed\"\nFROM pending_transactions\nWHERE $__timeFilter(created_at)\nGROUP BY 1\nORDER BY 1",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "type": "piechart",
      "title": "Current Status Distribution",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 5 },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "postgres"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "failed" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "red", "mode": "fixed" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "pending" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "orange", "mode": "fixed" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "completed" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "green", "mode": "fixed" }
              }
            ]
          }
        ]
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "pieType": "donut",
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "right" }
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "postgres"
          },
          "format": "table",
          "rawSql": "SELECT status, COUNT(*) AS count FROM pending_transactions GROUP BY status",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "type": "table",
      "title": "Failed & Stuck Transactions",
      "description": "Failed transactions or transactions pending > 10 minutes",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 13 },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "postgres"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "error_message" },
            "properties": [{ "id": "custom.width", "value": 400 }]
          },
          {
            "matcher": { "id": "byName", "options": "status" },
            "properties": [
              { "id": "custom.width", "value": 100 },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [{ "color": "red", "value": null }]
                }
              },
              { "id": "custom.displayMode", "value": "color-text" }
            ]
          }
        ]
      },
      "options": { "sortBy": [{ "displayName": "created_at", "desc": true }] },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "postgres"
          },
          "format": "table",
          "rawSql": "SELECT\n  id,\n  transaction_id,\n  chain_id,\n  status,\n  tx_hash,\n  error_message,\n  created_at,\n  updated_at,\n  EXTRACT(EPOCH FROM (NOW() - created_at)) / 60 AS age_minutes\nFROM pending_transactions\nWHERE status = 'failed'\n   OR (status = 'pending' AND created_at < NOW() - INTERVAL '10 minutes')\nORDER BY created_at DESC\nLIMIT 100",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "type": "bargauge",
      "title": "Transactions by Chain ID",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 21 },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "postgres"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "postgres"
          },
          "format": "table",
          "rawSql": "SELECT\n  'Chain ' || chain_id::text AS chain,\n  COUNT(*) AS total,\n  COUNT(*) FILTER (WHERE status = 'failed') AS failed\nFROM pending_transactions\nWHERE $__timeFilter(created_at)\nGROUP BY chain_id\nORDER BY total DESC",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Transaction Processing Rate (completed/min)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 21 },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "postgres"
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "color": { "fixedColor": "green", "mode": "fixed" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "postgres"
          },
          "format": "time_series",
          "rawSql": "SELECT\n  $__timeGroupAlias(updated_at,$__interval,'none'),\n  COUNT(*) AS \"Completed\"\nFROM pending_transactions\nWHERE status = 'completed'\n  AND $__timeFilter(updated_at)\nGROUP BY 1\nORDER BY 1",
          "refId": "A"
        }
      ]
    },
    {
      "id": 11,
      "type": "row",
      "title": "Idempotency Keys",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 29 }
    },
    {
      "id": 12,
      "type": "stat",
      "title": "Active (Pending) Keys",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 30 },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "postgres"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "postgres"
          },
          "format": "table",
          "rawSql": "SELECT COUNT(*) AS value FROM idempotency_keys WHERE status = 'pending' AND (expires_at IS NULL OR expires_at > NOW())",
          "refId": "A"
        }
      ]
    },
    {
      "id": 13,
      "type": "stat",
      "title": "Expiring in Next Hour",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 30 },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "postgres"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "postgres"
          },
          "format": "table",
          "rawSql": "SELECT COUNT(*) AS value FROM idempotency_keys WHERE expires_at BETWEEN NOW() AND NOW() + INTERVAL '1 hour'",
          "refId": "A"
        }
      ]
    },
    {
      "id": 14,
      "type": "stat",
      "title": "Expired Keys",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 30 },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "postgres"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 5000 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "postgres"
          },
          "format": "table",
          "rawSql": "SELECT COUNT(*) AS value FROM idempotency_keys WHERE expires_at IS NOT NULL AND expires_at < NOW()",
          "refId": "A"
        }
      ]
    },
    {
      "id": 15,
      "type": "stat",
      "title": "Total Idempotency Keys",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 30 },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "postgres"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "postgres"
          },
          "format": "table",
          "rawSql": "SELECT COUNT(*) AS value FROM idempotency_keys",
          "refId": "A"
        }
      ]
    },
    {
      "id": 16,
      "type": "piechart",
      "title": "Idempotency Key Status Distribution",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 34 },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "postgres"
      },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "pieType": "donut",
        "legend": { "displayMode": "list", "placement": "right" }
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "postgres"
          },
          "format": "table",
          "rawSql": "SELECT status, COUNT(*) AS count FROM idempotency_keys GROUP BY status ORDER BY count DESC",
          "refId": "A"
        }
      ]
    },
    {
      "id": 17,
      "type": "timeseries",
      "title": "Idempotency Keys Created Over Time",
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 34 },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "postgres"
      },
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 8 } },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "postgres"
          },
          "format": "time_series",
          "rawSql": "SELECT\n  $__timeGroupAlias(created_at,$__interval,'none'),\n  COUNT(*) FILTER (WHERE status = 'pending')   AS \"Pending\",\n  COUNT(*) FILTER (WHERE status = 'completed') AS \"Completed\",\n  COUNT(*) FILTER (WHERE status = 'expired')   AS \"Expired\"\nFROM idempotency_keys\nWHERE $__timeFilter(created_at)\nGROUP BY 1\nORDER BY 1",
          "refId": "A"
        }
      ]
    },
    {
      "id": 18,
      "type": "table",
      "title": "Recent Idempotency Keys",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 42 },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "postgres"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "expires_at" },
            "properties": [{ "id": "custom.width", "value": 200 }]
          }
        ]
      },
      "options": { "sortBy": [{ "displayName": "created_at", "desc": true }] },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "postgres"
          },
          "format": "table",
          "rawSql": "SELECT\n  id,\n  idempotency_key,\n  status,\n  request_hash,\n  created_at,\n  expires_at,\n  CASE WHEN expires_at IS NULL THEN 'never' WHEN expires_at < NOW() THEN 'expired' ELSE ROUND(EXTRACT(EPOCH FROM (expires_at - NOW())) / 60)::text || ' min' END AS expires_in\nFROM idempotency_keys\nORDER BY created_at DESC\nLIMIT 50",
          "refId": "A"
        }
      ]
    }
  ]
}
