# =============================================================================
# Production Environment Variables
# Copy to .env.production and fill in ALL values before deploying.
# NEVER commit this file with real credentials.
# =============================================================================

# ---------------------------------------------------------------------------
# Database (Postgres)
# ---------------------------------------------------------------------------
POSTGRES_USER=empx_prod
POSTGRES_PASSWORD=           # <-- strong random 64-char password
POSTGRES_DB=empxdb

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_PASSWORD=              # <-- strong random 64-char password

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
PORT=3000
NODE_ENV=production

JWT_SECRET=                  # <-- strong random 64-char secret
DASHBOARD_SECRET=            # <-- strong random secret

BCRYPT_ROUNDS=12
API_KEY_SALT_ROUNDS=12

# ---------------------------------------------------------------------------
# RPC Providers (use private/paid endpoints in production)
# ---------------------------------------------------------------------------
ETH_RPC_MAINNET=
POLYGON_RPC=
ARB_RPC=

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_DIR=logs
LOG_LEVEL=info
LOG_MAX_FILES=30d
LOG_CONSOLE=true
SERVICE_NAME=dex-aggregator-api

# ---------------------------------------------------------------------------
# CORS — comma-separated allowed origins
# ---------------------------------------------------------------------------
FRONTEND_ORIGINS=https://app.yourdomain.com

# ---------------------------------------------------------------------------
# Metrics & Observability
# ---------------------------------------------------------------------------
METRICS_TOKEN=               # <-- strong random token; must match prometheus.prod.yml
SLOW_REQUEST_MS=2000

# ---------------------------------------------------------------------------
# TLS / Traefik
# ---------------------------------------------------------------------------
ACME_EMAIL=                  # <-- your email for Let's Encrypt notifications
API_DOMAIN=api.yourdomain.com

# ---------------------------------------------------------------------------
# Grafana
# ---------------------------------------------------------------------------
GF_ADMIN_USER=empxadmin
GF_ADMIN_PASSWORD=           # <-- strong random password
