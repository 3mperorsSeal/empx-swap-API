
# JWT for sessions used by /v1/auth/user/login
JWT_SECRET=dev_jwt_secret_ChangeMe

# Dashboard secret (not used when JWT is present; kept for compatibility)
DASHBOARD_SECRET=dev_dashboard_secret

# Admin password used by seed script when ADMIN_PASSWORD provided
ADMIN_EMAIL=test@example.com
ADMIN_PASSWORD=ChangeMe123!

BCRYPT_ROUNDS=12
API_KEY_SALT_ROUNDS=12

# Local development environment variables
# Postgres (docker-compose) - adjust if using Railway or remote DB
DATABASE_URL=postgres://postgres:postgres@localhost:5432/dexdb

# Redis (docker-compose)
REDIS_URL=redis://localhost:6379

# Dev test API key (shown once during seed)
TEST_KEY=ak_f63fffc567c97528e405a79a0eec32c8a287d04961009d17

# App settings
PORT=3000
NODE_ENV=development
BCRYPT_ROUNDS=12

# RPC providers (replace with your keys/providers)
ETH_RPC_MAINNET=https://cloudflare-eth.com
POLYGON_RPC=https://rpc.ankr.com/polygon
ARB_RPC=https://rpc.ankr.com/arbitrum

# Optional: set to 'true' to enable verbose logs
LOG_VERBOSE=false

# Winston logging configuration
# Directory where logs will be written (relative or absolute)
LOG_DIR=logs
# Minimum log level: error, warn, info, verbose, debug, silly
LOG_LEVEL=info
# How many days to keep rotated logs (e.g., 14d)
LOG_MAX_FILES=14d
# When true, also print logs to console (useful in container STDOUT)
LOG_CONSOLE=true

# Service name for logging identification (ELK, Kibana, etc.)
SERVICE_NAME=dex-aggregator-api

# Frontend CORS whitelist (comma-separated)
FRONTEND_ORIGINS=http://localhost:5173,http://localhost:3000
