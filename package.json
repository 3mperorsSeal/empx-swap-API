{
  "name": "dex-aggregator-api",
  "version": "0.1.0",
  "main": "dist/src/index.js",
  "scripts": {
    "test": "jest --runInBand",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "prestart": "npm run build",
    "start": "node dist/src/index.js",
    "start:dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "start:prod": "cross-env NODE_ENV=production node dist/index.js",
    "worker": "ts-node src/infrastructure/queue/TransactionWorker.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "seed": "ts-node src/scripts/seed.ts",
    "migrate": "prisma migrate deploy",
    "migrate:dev": "prisma migrate dev",
    "prisma:generate": "prisma generate",
    "prisma:studio": "prisma studio"
  },
  "prisma": {
    "seed": "ts-node --transpile-only src/scripts/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^7.2.0",
    "bcrypt": "^5.1.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.18.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.3.1",
    "jsonwebtoken": "^9.0.0",
    "pg": "^8.17.1",
    "prom-client": "^15.1.3",
    "swagger-ui-express": "^4.6.3",
    "ts-node": "^10.9.2",
    "uuid": "^9.0.1",
    "viem": "^2.45.0",
    "winston": "^3.9.0",
    "winston-daily-rotate-file": "^4.7.1",
    "yamljs": "^0.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.3",
    "@types/node": "^20.19.30",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^2.0.12",
    "@types/uuid": "^10.0.0",
    "cross-env": "^7.0.3",
    "jest": "^29.6.1",
    "node-mocks-http": "^1.17.2",
    "prettier": "^3.8.1",
    "prisma": "^7.2.0",
    "supertest": "^7.1.3",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.1.6"
  }
}
